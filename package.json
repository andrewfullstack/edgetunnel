{
  "name": "edgetunnel",
  "version": "1.0.0",
  "description": "Cloudflare Workers proxy gateway (multi-file refactor)",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "analyze": "node build-analyze.mjs",
    "dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "npm run build && vitest run --config vitest.config.integration.ts",
    "test:all": "npm run test && npm run test:integration"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.21.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.90.0",
    "ws": "^8.20.0"
  }
}
